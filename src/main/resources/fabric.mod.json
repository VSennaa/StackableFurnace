{
  "schemaVersion": 1,
  "id": "stackable_furnace",
  "version": "${version}",
  "name": "Stackable Furnace",
  "description": "A multi-tier furnace that scales up to 4 levels of processing power within a single block. Features a built-in Turbo system for overclocked smelting and full hopper/pipe automation support.",
  "authors": [
    "VSenna"
  ],
  "contact": {
    "homepage": "https://github.com/VSennaa/StackableFurnace",
    "sources": "https://github.com/VSennaa/StackableFurnace/tree/main"
  },
  "license": "CC0-1.0",
  "icon": "assets/stackable_furnace/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.vsenna.stackable_furnace.StackableFurnace"
    ],
    "client": [
      "com.vsenna.stackable_furnace.StackableFurnaceClient"
    ]
  },
  "mixins": [
    "stackable-furnace.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "minecraft": "~1.20.6",
    "java": ">=21",
    "fabric-api": "*"
  }
}